#!/bin/bash
WINDOW_ID=$(/opt/homebrew/bin/yabai -m query --windows | jq -r '.[] | select(.app=="Ghostty" and .title=="mini") | .id' | head -n1)

if [ -n "$WINDOW_ID" ]; then
    # Window exists, focus it
    /opt/homebrew/bin/yabai -m window --focus "$WINDOW_ID"
else
    # Window doesn't exist, create it
    open -na Ghostty.app --args --window-width=148 --window-height=49 --title="mini" --command=/bin/zsh --quit-after-last-window-closed=true

    # Wait for the window to be created with a timeout
    max_attempts=20
    attempt=0
    new_window_id=""

    while [ -z "$new_window_id" ] && [ $attempt -lt $max_attempts ]; do
        new_window_id=$(/opt/homebrew/bin/yabai -m query --windows | jq -r '.[] | select(.app=="Ghostty" and .title=="mini") | .id' | tail -n1)
        attempt=$((attempt + 1))
    done

    # Position the window using /opt/homebrew/bin/yabai if it was found
    if [ -n "$new_window_id" ]; then
        /opt/homebrew/bin/yabai -m window $new_window_id --toggle float --grid 1291:2056:340:178:1410:1060
        /opt/homebrew/bin/yabai -m window --focus $new_window_id
    else
        echo "Failed to detect new Ghostty window after $max_attempts attempts"
    fi
fi
