#!/usr/bin/env bash
set -u

if [[ $# -lt 1 ]]; then
  echo "Usage: $(basename "$0") [ssh args...]" >&2
  exit 2
fi

while :; do
  trap - INT
  ssh "$@"
  rc=$?

  echo
  echo "ssh ended (exit code $rc). Press Enter to reconnect. (Close terminal to stop.)"

  trap '' INT
  while ! IFS= read -r _; do :; done
done
