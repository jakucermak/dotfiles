// Zed settings // // For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "ssh_connections": [
    {
      "host": "hug5",
      "projects": [
        {
          "paths": ["/root"]
        },
        {
          "paths": ["~/bk_scripts"]
        }
      ]
    },
    {
      "host": "hug5",
      "projects": [
        {
          "paths": ["~/bk-clone-db.sh"]
        }
      ]
    }
  ],
  "bottom_dock_layout": "contained",
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },
  "icon_theme": "Colored Zed Icons Theme Light",
  "outline_panel": {
    "dock": "right"
  },
  "minimap": {
    "show": "always",
    "thumb": "always"
  },
  "features": {
    "edit_prediction_provider": "none"
  },
  "cursor_blink": false,
  "scrollbar": {
    "show": "never"
  },
  "vertical_scroll_margin": 0,
  "theme": {
    "mode": "system",
    "light": "Ayu Light Flat (Blur)",
    "dark": "Ayu Dark Flat (Blur)"
  },
  "ui_font_size": 17,
  "buffer_font_size": 15,
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "tab_bar": {
    "show": false
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false
  },
  "show_whitespaces": "all",

  "language_models": {
    "openai": {
      "version": "1",
      "available_models": []
    }
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet-latest"
    },
    "version": "2"
  },
  "terminal": {
    "dock": "left",
    "font_family": "JetBrainsMono Nerd Font"
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never"
  },
  "git": {
    "git_gutter": "tracked_files",
    "gutter_debounce": 1000,
    "inline_blame": {
      "enabled": true,
      "show_hover": true
    }
  },
  "relative_line_numbers": true,
  "jupyter": {
    "kernel_selections": {
      "python": "conda-env",
      "typescript": "deno",
      "javascript": "deno"
    }
  },
  "lsp": {
    "ansible-language-server": {
      "settings": {
        "ansible": {
          "path": "/etc/profiles/per-user/jakubcermak/bin/ansible"
        },
        "executionEnvironment": {
          "enabled": false
        },
        "python": {
          "interpreterPath": "python3"
        },
        "validation": {
          "enabled": true,
          "lint": {
            "enabled": true,
            "path": "ansible-lint"
          }
        }
      }
    },
    "nixd": {
      "settings": {
        "diagnostic": {
          "suppress": ["sema-extra-with"]
        }
      }
    }
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "nil"]
    }
  },
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**/defaults/**.yml",
      "**/defaults/**.yaml",
      "**/meta/**.yml",
      "**/meta/**.yaml",
      "**/tasks/**.yml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/**.yml",
      "**/group_vars/**.yaml",
      "**playbook*.yaml",
      "**playbook*.yml",
      "/Users/jakubcermak/HUG/ansible_playbooks/*.yml"
    ]
  }
}
